ENV=dev

# App
APP_NAME=Development Outsourcing Platform
APP_DESCRIPTION=LLM 기반 외주 고도화 플랫폼 백엔드
APP_VERSION=0.1.0
API_PREFIX=/api
DOCS_URL=/api/docs
REDOC_URL=/api/redoc
OPENAPI_URL=/api/openapi.json

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_SECRET_KEY=very-secret-key-change-it-in-prod
REFRESH_TOKEN_SECRET_KEY=very-secret-key-change-it-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Runtime
DEBUG=true
SQLALCHEMY_ECHO=true
FRONTEND_CORS_ORIGIN=[]
LOG_LEVEL=DEBUG
LOG_FORMAT=uvicorn
LOG_DEBUG=true

# RDBMS
DATABASE_URL=postgresql+asyncpg://dop:dop@localhost:5432/development_outsourcing_platform

# In-Memory Database
VALKEY_URL=redis://localhost:6379/0
